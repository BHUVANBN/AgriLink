# ==============================================================
# AgriLink v2 — Environment Variables
# Copy this to .env and fill in all values before running.
# NEVER commit your .env file.
# ==============================================================

# ── Node ──────────────────────────────────────────────────────
NODE_ENV=development

# ── Auth Service ──────────────────────────────────────────────
AUTH_PORT=4001

MONGODB_AUTH_URI=""
# Generate: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_REFRESH_SECRET=CHANGE_ME_different_secret_for_refresh
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=7d

# ── Farmer Service ────────────────────────────────────────────
FARMER_PORT=4002
MONGODB_FARMER_URI=""
# ── Supplier Service ──────────────────────────────────────────
SUPPLIER_PORT=4003
# Postgres connection string for supplier DB
DATABASE_URL_SUPPLIER=postgresql://agrilink:agrilink_dev@localhost:5432/agrilink_supplier

# ── Marketplace Service ───────────────────────────────────────
MARKETPLACE_PORT=4004
DATABASE_URL_MARKETPLACE=postgresql://agrilink:agrilink_dev@localhost:5432/agrilink_marketplace
# Razorpay (BUG-011 fix: real payment gateway)
# Get from https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=rzp_test_CHANGE_ME
RAZORPAY_KEY_SECRET=CHANGE_ME

# ── Notification Service ──────────────────────────────────────
NOTIFICATION_PORT=4005
# SMTP (Gmail: enable App Password at myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=bhuvanbn01@gmail.com
SMTP_PASS=
SMTP_FROM=AgriLink <noreply@agrilink.app>
# Fast2SMS (BUG-005 fix: correct transactional route)
# Register at https://www.fast2sms.com/
FAST2SMS_API_KEY=

# ── ML Service ────────────────────────────────────────────────
ML_PORT=4006
MONGODB_ML_URI=""
# Google Cloud Vision AI (BUG-018 fix: Kannada OCR)
# Create service account at console.cloud.google.com -> IAM -> Service Accounts
GOOGLE_APPLICATION_CREDENTIALS=/path/to/gcp-service-account.json
# Google Gemini (BUG-019 fix: AI field extraction)
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=CHANGE_ME

# ── Blockchain Service ────────────────────────────────────────
BLOCKCHAIN_PORT=4007
# Alchemy / Infura / QuickNode RPC URL for Polygon Amoy Testnet
# https://dashboard.alchemy.com/ -> Create App -> Polygon Amoy
BLOCKCHAIN_RPC_URL=https://polygon-amoy.g.alchemy.com/v2/CHANGE_ME
BLOCKCHAIN_ADMIN_PRIVATE_KEY=0xCHANGE_ME_farmer_admin_wallet_private_key
# Filled after: pnpm --filter @agrilink/blockchain deploy:amoy
BLOCKCHAIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
BLOCKCHAIN_NETWORK=amoy  # Use 'polygon' for mainnet
# PolygonScan API key for contract verification
POLYGONSCAN_API_KEY=CHANGE_ME
# Pinata IPFS (BUG-015 fix: replaces deprecated Web3.Storage)
# https://app.pinata.cloud/ -> API Keys -> Generate New Key
PINATA_JWT=CHANGE_ME
PINATA_GATEWAY=https://gateway.pinata.cloud

# ── Shared Infrastructure ─────────────────────────────────────
POSTGRES_PASSWORD=agrilink_dev_secret
REDIS_URL=redis://localhost:6379
KAFKA_BROKERS=localhost:29092

# ── Cloudinary (File storage) ─────────────────────────────────
# https://cloudinary.com/ -> Dashboard -> Account Details
CLOUDINARY_CLOUD_NAME=dxfpm6vjo
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# ── Frontend ──────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_CHANGE_ME  # Same as RAZORPAY_KEY_ID

# ── CORS ─────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ── Monitoring ────────────────────────────────────────────────
GRAFANA_PASSWORD=admin_CHANGE_ME

# ── Optional ──────────────────────────────────────────────────
# Allowed origins for production
ALLOWED_ORIGINS=https://agrilink.app
